{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "outDir": "dist",
        "rootDir": ".",
        "baseUrl": ".",
        "paths": {
            "@src/*": [
                "src/*"
            ],
            "@cli/*": [
                "cli/*"
            ]
        }
    },
    "include": [
        "src/**/*.ts",
        "cli/**/*.ts",
        "cli/**/*.tsx"
    ]
}